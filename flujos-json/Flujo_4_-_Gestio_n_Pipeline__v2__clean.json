    {
      "parameters": {
        "jsCode": "const d = $input.first().json;\nlet msg = `⏰ <b>FundingFlow — Recordatorios de pipeline</b>\\n`;\nmsg += `${d.total} propuesta(s) con fecha límite en los próximos 14 días\\n\\n`;\n\nfor (const r of d.recordatorios) {\n  msg += `${r.urgencia} <b>${r.nombre}</b>\\n`;\n  msg += `  📊 Estado: ${r.estado}\\n`;\n  msg += `  👤 Responsable: ${r.responsable}\\n`;\n  msg += `  📅 Fecha límite: ${r.fecha_limite} (${r.dias_restantes} días)\\n`;\n  if (r.donante) msg += `  🏛️ Donante: ${r.donante}\\n`;\n  if (r.monto) msg += `  💰 Monto: ${r.monto}\\n`;\n  if (r.url) msg += `  🔗 <a href=\"${r.url}\">Ver convocatoria</a>\\n`;\n  msg += `\\n`;\n}\n\nmsg += `—\\nFundingFlow · ${new Date().toLocaleString('es-ES')}`;\nreturn [{ json: { mensaje: msg, total: d.total } }];"
      },
