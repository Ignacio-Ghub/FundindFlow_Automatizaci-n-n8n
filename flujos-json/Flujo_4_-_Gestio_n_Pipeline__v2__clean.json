        "jsCode": "const payload = $('Code: Validar payload').first().json;\nconst registros = $input.all();\nif (registros.length === 0 || !registros[0].json.ID_Convocatoria) {\n  return [{ json: { existe: false, error: 'No existe registro con ID: ' + payload.convocatoria_id, ...payload }}];\n}\nconst reg = registros[0].json;\nreturn [{ json: {\n  existe: true,\n  action: payload.action,\n  convocatoria_id: payload.convocatoria_id,\n  nuevo_estado: payload.nuevo_estado || '',\n  responsable: payload.responsable || '',\n  comentario: payload.comentario || '',\n  usuario: payload.usuario || 'sistema',\n  timestamp: payload.timestamp,\n  nombre_conv: reg.Nombre || reg.Titulo || reg.ID_Convocatoria || 'Sin nombre',\n  estado_anterior: reg.Estado || 'sin estado',\n  donante_conv: reg.Donante || 'sin donante',\n  fecha_limite_conv: reg.Fecha_Limite || 'sin fecha',\n  url_conv: reg.Convocatoria_URL || reg.URL || '',\n  responsable_actual: reg.Responsable || 'sin asignar',\n  notas_actuales: reg.Notas || ''\n}}];"
