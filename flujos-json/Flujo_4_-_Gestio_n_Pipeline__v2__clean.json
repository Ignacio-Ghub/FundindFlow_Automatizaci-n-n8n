    {
      "parameters": {
        "jsCode": "const items = $input.all();\nconst hoy = new Date();\nhoy.setHours(0,0,0,0);\n\nconst ESTADOS_ACTIVOS = ['en_análisis','en_elaboración','concept_note','propuesta_completa'];\nconst recordatorios = [];\n\nfor (const item of items) {\n  const d = item.json;\n  if (!ESTADOS_ACTIVOS.includes(d.Estado)) continue;\n  if (!d.Fecha_Limite) continue;\n\n  let fechaLimite;\n  try {\n    if (d.Fecha_Limite.includes('/')) {\n      const parts = d.Fecha_Limite.split('/');\n      fechaLimite = new Date(parts[2], parts[1]-1, parts[0]);\n    } else {\n      fechaLimite = new Date(d.Fecha_Limite);\n    }\n    if (isNaN(fechaLimite.getTime())) continue;\n  } catch(e) { continue; }\n\n  fechaLimite.setHours(0,0,0,0);\n  const diasRestantes = Math.round((fechaLimite - hoy) / (1000*60*60*24));\n  if (diasRestantes < 0 || diasRestantes > 14) continue;\n\n  recordatorios.push({\n    id: d.ID_Convocatoria,\n    nombre: d.Nombre || d.Titulo || 'Sin nombre',\n    estado: d.Estado,\n    responsable: d.Responsable || 'Sin asignar',\n    fecha_limite: d.Fecha_Limite,\n    dias_restantes: diasRestantes,\n    donante: d.Donante || '',\n    monto: d.Monto_Solicitado || '',\n    url: d.Convocatoria_URL || d.URL || '',\n    urgencia: diasRestantes <= 3 ? '🔴' : diasRestantes <= 7 ? '🟡' : '🟢'\n  });\n}\n\nrecordatorios.sort((a, b) => a.dias_restantes - b.dias_restantes);\n\nif (recordatorios.length === 0) {\n  return [{ json: { hay_recordatorios: false } }];\n}\n\nreturn [{ json: { hay_recordatorios: true, recordatorios, total: recordatorios.length } }];"
      },
