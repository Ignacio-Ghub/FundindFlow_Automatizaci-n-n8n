      "parameters": {
        "jsCode": "const raw = $input.first().json;\nconst body = raw.body || raw.data || raw;\n\nconst required = ['action', 'convocatoria_id'];\nfor (const field of required) {\n  if (!body[field]) {\n    return [{ json: { valid: false, error: `Campo obligatorio ausente: ${field}`, status: 400 } }];\n  }\n}\n\nconst ESTADOS_VALIDOS = ['en_análisis','en_elaboración','concept_note','propuesta_completa','enviada','en_negociación','aprobada','rechazada','archivada'];\nconst ACCIONES_VALIDAS = ['cambio_estado', 'asignar', 'comentario'];\n\nif (!ACCIONES_VALIDAS.includes(body.action)) {\n  return [{ json: { valid: false, error: `Acción no válida: ${body.action}`, status: 400 } }];\n}\n\nif (body.action === 'cambio_estado' && body.nuevo_estado && !ESTADOS_VALIDOS.includes(body.nuevo_estado)) {\n  return [{ json: { valid: false, error: `Estado no válido: ${body.nuevo_estado}`, status: 400 } }];\n}\n\nreturn [{ json: {\n  valid: true,\n  action: body.action,\n  convocatoria_id: body.convocatoria_id,\n  nuevo_estado: body.nuevo_estado || null,\n  responsable: body.responsable || null,\n  comentario: body.comentario || null,\n  usuario: body.usuario || 'sistema',\n  timestamp: new Date().toISOString()\n}}];"
      },
