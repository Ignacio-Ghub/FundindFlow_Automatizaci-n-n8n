      "name": "Merge: Todas las fuentes",
      "type": "n8n-nodes-base.merge",
      "typeVersion": 3,
      "position": [
        -1392,
        864
      ],
      "id": "dc0d7e77-e109-4e7e-b71e-4f84f206a403"
    },
    {
      "parameters": {
        "jsCode": "const items = $input.all();\nconst normalized = [];\n\nconst SOURCE_MAP = {\n  'fundsforngos.org': 'FundsForNGOs',\n  'terravivagrants.org': 'TerraViva Grants',\n  'grant4.eu': 'Grant4EU'\n};\n\nfunction detectSource(url) {\n  for (const [domain, name] of Object.entries(SOURCE_MAP)) {\n    if ((url || '').includes(domain)) return name;\n  }\n  return 'Fuente RSS';\n}\n\nfor (const item of items) {\n  const d = item.json;\n  if (!d || d.error) continue;\n\n  const url = d.link || d.url || d.guid || '';\n  const title = (d.title || '').trim();\n  if (!title || !url) continue;\n\n  // Snippet del RSS como fallback si el scraping falla\n  const snippet = (d.contentSnippet || d.content || d.description || '')\n    .replace(/<[^>]+>/g, ' ')\n    .replace(/\\s+/g, ' ')\n    .trim()\n    .substring(0, 500);\n\n  const pubDate = d.pubDate || d.isoDate || null;\n  const source_name = detectSource(url);\n  const prefijo = source_name.substring(0, 3).toUpperCase();\n  const random_str = Math.random().toString(36).substring(2, 8).toUpperCase();\n  const id_corto = prefijo + '-' + random_str;\n\n  normalized.push({ json: {\n    id_corto,\n    clave_deduplicacion: url,\n    source_name,\n    title_raw: title,\n    snippet_rss: snippet,\n    url,\n    pub_date: pubDate\n  }});\n}\n\nreturn normalized;"
      },
      "name": "Code: Normalización",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -1136,
        864
      ],
      "id": "b74ffc86-4884-49d1-becf-a32b49d9c81e"
    },
    {
      "parameters": {
        "jsCode": "const items = $input.all();\nconst staticData = $getWorkflowStaticData('global');\n\n// Reset forzado — quitar esta línea después de ejecutar una vez\nstaticData.seenUrls = {};\n\n// Limpiar entradas mayores de 90 días\nconst now = new Date();\nfor (const [key, date] of Object.entries(staticData.seenUrls)) {\n  if ((now - new Date(date)) / (1000 * 60 * 60 * 24) > 90) {\n    delete staticData.seenUrls[key];\n  }\n}\n\nconst finalItems = [];\nfor (const item of items) {\n  const d = item.json;\n  const key = d.clave_deduplicacion;\n  if (!key || staticData.seenUrls[key]) {\n    d.es_nuevo = false;\n  } else {\n    staticData.seenUrls[key] = new Date().toISOString();\n    d.es_nuevo = true;\n  }\n  finalItems.push({ json: d });\n}\nreturn finalItems;"
      },
