      "name": "HTTP: Scraping artículo",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        -368,
        736
      ],
      "id": "d16396d9-37ff-444d-8055-c534a1e47142",
      "continueOnFail": true
    },
    {
      "parameters": {
        "jsCode": "const item = $input.first();\n\n// Los datos originales están en el nodo IF, no en el HTTP\n// porque el HTTP sobreescribe el item con el HTML\nconst original = $('IF: ¿Es nuevo?').first().json;\n\nconst id_corto = original.id_corto || '';\nconst title_raw = original.title_raw || '';\nconst source_name = original.source_name || '';\nconst url = original.url || '';\nconst pub_date = original.pub_date || '';\nconst clave_deduplicacion = original.clave_deduplicacion || '';\nconst snippet_rss = original.snippet_rss || '';\n\nlet contenido_final = snippet_rss;\n\n// Buscar HTML en el item actual (viene del HTTP Request)\nlet htmlRaw = '';\nif (typeof item.json.data === 'string') htmlRaw = item.json.data;\nelse if (typeof item.json.body === 'string') htmlRaw = item.json.body;\nelse if (item.json.data?.body && typeof item.json.data.body === 'string') htmlRaw = item.json.data.body;\n\nif (htmlRaw.length > 100) {\n  const articleMatch =\n    htmlRaw.match(/<article[^>]*>([\\s\\S]*?)<\\/article>/i) ||\n    htmlRaw.match(/<main[^>]*>([\\s\\S]*?)<\\/main>/i) ||\n    htmlRaw.match(/class=\"[^\"]*(?:entry|post|content)[^\"]*\"[^>]*>([\\s\\S]*?)<\\/div>/i);\n\n  let texto = articleMatch ? articleMatch[1] : htmlRaw;\n\n  texto = texto\n    .replace(/<script[\\s\\S]*?<\\/script>/gi, ' ')\n    .replace(/<style[\\s\\S]*?<\\/style>/gi, ' ')\n    .replace(/<[^>]+>/g, ' ')\n    .replace(/&nbsp;/g, ' ')\n    .replace(/&amp;/g, '&')\n    .replace(/&lt;/g, '<')\n    .replace(/&gt;/g, '>')\n    .replace(/&quot;/g, '\"')\n    .replace(/\\s+/g, ' ')\n    .trim();\n\n  if (texto.length > contenido_final.length) {\n    contenido_final = texto.substring(0, 3000);\n  }\n}\n\nif (!contenido_final || contenido_final.length < 50) {\n  contenido_final = snippet_rss || 'Sin contenido disponible';\n}\n\nreturn [{ json: {\n  id_corto,\n  clave_deduplicacion,\n  source_name,\n  title_raw,\n  snippet_rss,\n  url,\n  pub_date,\n  Contenido_Raw: contenido_final\n}}];"
      },
